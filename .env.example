# Copy this file to .env and set every secret locally.
# Never commit .env or replace blank secret values in this example.

# API KEYS and CREDENTIALS
ALPACA_API_KEY=
ALPACA_API_SECRET_KEY=
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
FIRECRAWL_API_KEY=
FMP_API_KEY=
FRED_API_KEY=
MASSIVE_API_KEY=
NEWSAPI_API_KEY=
OLLAMA_API_KEY=

# QDRANT
QDRANT_HOST=localhost
QDRANT_PORT=6333

# OLLAMA
OLLAMA_HOST=http://localhost:11434

# POSTGRESQL
POLARIS_DATABASE_URL=
POLARIS_POSTGRES_HOST=localhost
POLARIS_POSTGRES_PORT=5432
POLARIS_POSTGRES_DB=polaris
POLARIS_POSTGRES_USER=polaris
POLARIS_POSTGRES_PASSWORD=
POLARIS_POSTGRES_DRIVER=asyncpg
POLARIS_POSTGRES_ECHO=false
POLARIS_POSTGRES_POOL_PRE_PING=true

# Neo4j expects the form <username>/<password>.
NEO4J_AUTH=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
