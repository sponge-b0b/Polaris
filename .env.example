# Copy this file to .env and set every secret locally.
# Never commit .env or replace blank secret values in this example.

# API KEYS and CREDENTIALS
ALPACA_API_KEY=
ALPACA_API_SECRET_KEY=
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
MASSIVE_API_KEY=
NEWSAPI_API_KEY=

# QDRANT
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LiteLLM gateway. Local proxy defaults to Ollama-backed models through Docker Compose.
POLARIS_LITELLM_ENABLED=false
POLARIS_LITELLM_BASE_URL=http://localhost:4000/v1
POLARIS_LITELLM_API_KEY=
POLARIS_LITELLM_TIMEOUT_SECONDS=60
POLARIS_LITELLM_STRICT_MODE=false
# Must be reachable from the LiteLLM container. If host Ollama binds only 127.0.0.1, restart Ollama with OLLAMA_HOST=0.0.0.0:11434 or set this to another reachable endpoint.
POLARIS_LITELLM_OLLAMA_API_BASE=http://host.docker.internal:11434

# RAG web fallback: SearXNG handles search/discovery; Crawl4AI handles content acquisition.
RAG_WEB_FALLBACK_ENABLED=false
RAG_WEB_FALLBACK_MAX_RESULTS=5
SEARXNG_BASE_URL=http://localhost:8888
SEARXNG_TIMEOUT_SECONDS=15
SEARXNG_SAFE_SEARCH=1
SEARXNG_LANGUAGE=en
SEARXNG_CATEGORIES=general
CRAWL4AI_TIMEOUT_SECONDS=30
CRAWL4AI_HEADLESS=true
CRAWL4AI_CACHE_ENABLED=true
CRAWL4AI_MAX_CONCURRENCY=4
CRAWL4AI_USER_AGENT=

# POSTGRESQL
POLARIS_DATABASE_URL=
POLARIS_POSTGRES_HOST=localhost
POLARIS_POSTGRES_PORT=5432
POLARIS_POSTGRES_DB=polaris
POLARIS_POSTGRES_USER=polaris
POLARIS_POSTGRES_PASSWORD=
POLARIS_POSTGRES_DRIVER=asyncpg
POLARIS_POSTGRES_ECHO=false
POLARIS_POSTGRES_POOL_PRE_PING=true

# Neo4j
NEO4J_AUTH=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Langfuse service database settings used by Docker Compose.
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=

# Polaris Langfuse AI-observability export settings.
POLARIS_LANGFUSE_HOST=http://localhost:3000
POLARIS_LANGFUSE_PUBLIC_KEY=
POLARIS_LANGFUSE_SECRET_KEY=

# Polaris DeepEval LLM-evaluation settings.
POLARIS_DEEPEVAL_ENABLED=true
POLARIS_DEEPEVAL_JUDGE_PROVIDER=
POLARIS_DEEPEVAL_JUDGE_MODEL=polaris-local-evaluation
POLARIS_DEEPEVAL_STRICT_MODE=false
POLARIS_DEEPEVAL_TELEMETRY_OPT_OUT=true
POLARIS_DEEPEVAL_DEFAULT_THRESHOLD=0.7
POLARIS_DEEPEVAL_MAX_CONCURRENCY=4
POLARIS_DEEPEVAL_TIMEOUT_SECONDS=60

# RAG model-operation aliases. Concrete local models are mapped in
# config/litellm/config.yaml so source defaults stay provider-neutral.
POLARIS_RAG_QUERY_REWRITE_MODEL=polaris-local-fast
POLARIS_RAG_ADAPTIVE_TRIAGE_MODEL=polaris-local-fast
POLARIS_RAG_ROUTE_SELECTION_MODEL=polaris-local-structured
POLARIS_RAG_HYDE_MODEL=polaris-local-reasoning
POLARIS_RAG_CRAG_GRADER_MODEL=polaris-local-structured
POLARIS_RAG_CRAG_QUERY_REWRITE_MODEL=polaris-local-structured
POLARIS_RAG_SELF_REFLECTION_MODEL=polaris-local-structured
POLARIS_RAG_SYNTHESIS_MODEL=polaris-local-synthesis
POLARIS_RAG_STRUCTURED_MAX_TOKENS=512
POLARIS_RAG_HYDE_MAX_TOKENS=768
POLARIS_RAG_SYNTHESIS_MAX_TOKENS=1536

# STRUCTURED OUTPUT / INSTRUCTOR
POLARIS_STRUCTURED_OUTPUT_PROVIDER=instructor
POLARIS_STRUCTURED_OUTPUT_MODEL=polaris-local-structured
POLARIS_STRUCTURED_OUTPUT_MAX_RETRIES=2
POLARIS_STRUCTURED_OUTPUT_TIMEOUT_SECONDS=60
POLARIS_STRUCTURED_OUTPUT_MAX_TOKENS=4096
POLARIS_STRUCTURED_OUTPUT_STRICT=false
POLARIS_STRUCTURED_OUTPUT_INSTRUCTOR_MODE=json

# DSPY OPTIMIZATION
POLARIS_DSPY_ENABLED=false
POLARIS_DSPY_OPTIMIZATION_MODEL=polaris-local-optimization
POLARIS_DSPY_MAX_TRAINSET_CASES=100
POLARIS_DSPY_ARTIFACT_RETENTION_DAYS=90
