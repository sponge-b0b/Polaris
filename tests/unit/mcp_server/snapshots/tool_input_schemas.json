{
  "polaris_completed_run_get": {
    "$defs": {
      "CompletedRunSection": {
        "enum": [
          "workflow_inputs",
          "node_outputs",
          "errors",
          "artifact_refs",
          "trace_context"
        ],
        "title": "CompletedRunSection",
        "type": "string"
      }
    },
    "additionalProperties": false,
    "description": "Input contract for ``polaris_completed_run_get``.",
    "properties": {
      "execution_id": {
        "minLength": 1,
        "title": "Execution Id",
        "type": "string"
      },
      "include": {
        "default": [],
        "items": {
          "$ref": "#/$defs/CompletedRunSection"
        },
        "title": "Include",
        "type": "array",
        "uniqueItems": true
      },
      "node_names": {
        "default": [],
        "items": {
          "minLength": 1,
          "type": "string"
        },
        "title": "Node Names",
        "type": "array"
      },
      "workflow_name": {
        "minLength": 1,
        "title": "Workflow Name",
        "type": "string"
      }
    },
    "required": [
      "workflow_name",
      "execution_id"
    ],
    "title": "CompletedRunGetRequest",
    "type": "object"
  },
  "polaris_completed_runs_list": {
    "additionalProperties": false,
    "description": "Input contract for ``polaris_completed_runs_list``.",
